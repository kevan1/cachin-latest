# Cachin mobile app / Expo public config
# Copy to .env for local development. Do not commit real .env values.

# App identity and URLs
EXPO_PUBLIC_APP_SCHEME=
EXPO_PUBLIC_API_URL=
EXPO_PUBLIC_PASSKEY_ASSOCIATED_DOMAIN=

# Privy client/public config
EXPO_PUBLIC_PRIVY_APP_ID=
EXPO_PUBLIC_PRIVY_CLIENT_ID=
EXPO_PUBLIC_PRIVY_EXPORT_CLIENT_ID=
EXPO_PUBLIC_PRIVY_EXPORT_PAGE_URL=
EXPO_PUBLIC_PRIVY_GAS_SPONSOR_POLICY_IDS=
EXPO_PUBLIC_PRIVY_KEY_QUORUM_ID=
EXPO_PUBLIC_PRIVY_LOG_USER_JWT=
# Optional fallback only. Prefer the backend-generated Sumsub link flow.
EXPO_PUBLIC_SUMSUB_VERIFICATION_URL=

# Firebase client config. These are public client identifiers; restrict Firebase rules.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Solana/paymaster client config
EXPO_PUBLIC_SOLANA_RPC=
EXPO_PUBLIC_SOLANA_CAIP2=
EXPO_PUBLIC_AVALANCHE_RPC=
EXPO_PUBLIC_PAYMASTER_ENABLED=
EXPO_PUBLIC_PAYMASTER_PUBLIC_KEY=
EXPO_PUBLIC_PAYMASTER_API_URL=
EXPO_PUBLIC_PAYMASTER_BACKEND_URL=

# Third-party client IDs
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
EXPO_PUBLIC_CRISP_WEBSITE_ID=
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_APPLE_CLIENT_ID=
EXPO_PUBLIC_DISCORD_CLIENT_ID=
EXPO_PUBLIC_FACEBOOK_CLIENT_ID=
EXPO_PUBLIC_X_CLIENT_ID=

# Turnkey legacy/public config if still used by older flows
EXPO_PUBLIC_TURNKEY_ORGANIZATION_ID=
EXPO_PUBLIC_TURNKEY_API_BASE_URL=
EXPO_PUBLIC_TURNKEY_AUTH_PROXY_URL=
EXPO_PUBLIC_TURNKEY_AUTH_PROXY_CONFIG_ID=
EXPO_PUBLIC_TURNKEY_RPID=

# Legacy/unprefixed app config fallbacks. Prefer the matching EXPO_PUBLIC_* variable
# where available; these may still be read by app.config.ts/runtimeConfig and exposed
# in a client build.
GOOGLE_MAPS_API_KEY=
PASSKEY_ASSOCIATED_DOMAIN=
PRIVY_EXPORT_CLIENT_ID=
PRIVY_EXPORT_PAGE_URL=
SUMSUB_VERIFICATION_URL=

# Backend/API Privy config. Secrets stay server-only; non-secret IDs below may also
# be legacy app config fallbacks, so prefer EXPO_PUBLIC_* for client builds.
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_JWT_VERIFICATION_KEY=
PRIVY_AUTHORIZATION_KEY=
PRIVY_AUTHORIZATION_KEY_ID=
PRIVY_KEY_QUORUM_ID=
PRIVY_GAS_SPONSOR_POLICY_IDS=
PRIVY_DEBUG=

# Server-only paymaster/Solana config
PAYMASTER_SECRET_KEY=
PAYMASTER_PRIVATE_KEY=
PAYMASTER_PUBLIC_KEY=
SOLANA_RPC=
SOLANA_CAIP2=

# Server-only P2P.me / ARS bridge config
P2P_EVM_RPC=
P2P_EVM_CHAIN=
P2P_EVM_CHAIN_ID=
P2P_DIAMOND_ADDRESS=
P2P_USDC_ADDRESS=
P2P_SUBGRAPH_URL=
P2P_RELAYER_PRIVATE_KEY=
P2P_BRIDGE_SIM_FEE_BPS=

# Server-only Manteca config. Fill after Manteca.dev provides the key.
MANTECA_API_KEY=
MANTECA_API_BASE_URL=
MANTECA_QR_PAYMENT_URL=
MANTECA_QR_PAYMENT_PATH=

# Server-only Sumsub config for fresh verification links.
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
SUMSUB_LEVEL_NAME=
SUMSUB_WEBSDK_TTL=
SUMSUB_CALLBACK_URL=

# Server-only receive push notification config.
# HELIUS_WEBHOOK_URL defaults to https://api.cachin.app/api/push/helius-webhook.
FIREBASE_SERVICE_ACCOUNT_JSON=
HELIUS_API_KEY=
HELIUS_WEBHOOK_ID=
HELIUS_WEBHOOK_AUTH_HEADER=
HELIUS_WEBHOOK_URL=
PUSH_ADMIN_SECRET=
